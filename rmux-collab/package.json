{
  "name": "rmux-collab",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "rmux-collab": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "start": "tsx src/cli.ts",
    "example:basic": "tsx examples/basic-ask.ts",
    "example:broadcast": "tsx examples/broadcast-test.ts",
    "example:e2e": "tsx examples/coordinator-e2e.ts"
  },
  "dependencies": {
    "@rmux/sdk": "^0.6.5"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
